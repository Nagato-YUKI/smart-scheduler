{
  "name": "智能排课系统",
  "description": "基于Python/Flask后端 + Vue3前端的全栈排课解决方案",
  "version": "1.0.0",
  "author": "Nagato-YUKI",
  "license": "MIT",
  "repository": "https://github.com/Nagato-YUKI/smart-scheduler",
  "scripts": {
    "install:backend": "cd backend && pip install -r requirements.txt",
    "install:frontend": "cd frontend && npm install",
    "install:all": "npm run install:backend && npm run install:frontend",
    "dev:backend": "cd backend && python app.py",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "cd frontend && npm run build"
  },
  "backend": {
    "runtime": "python",
    "version": "3.10",
    "entry": "backend/app.py",
    "port": 5000,
    "dependencies": [
      "Flask==3.1.0",
      "flask-cors==5.0.1",
      "openpyxl==3.1.5",
      "python-dotenv==1.0.1",
      "peewee==3.17.8"
    ]
  },
  "frontend": {
    "runtime": "node",
    "version": "18",
    "framework": "vue3",
    "port": 5173,
    "build": {
      "command": "npm run build",
      "output": "frontend/dist"
    }
  },
  "environment": {
    "NODE_ENV": "production",
    "PYTHONPATH": "./backend",
    "SECRET_KEY": "your-secret-key-here"
  },
  "features": [
    "数据管理：教室/教师/班级/课程CRUD",
    "Excel批量导入",
    "智能排课算法",
    "多维度课表查看",
    "排课统计分析"
  ]
}
